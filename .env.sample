# Telegram (required)
TELEGRAM_BOT_TOKEN=

# RapidAPI (required for downloading)
RAPIDAPI_KEY=

# RapidAPI host (optional)
# Default: tiktok-api23.p.rapidapi.com
RAPIDAPI_HOST=tiktok-api23.p.rapidapi.com

# MongoDB (optional). If missing, bot runs fully in-memory.
MONGODB_URI=

# Admin-only stats (optional)
# Comma-separated Telegram numeric user IDs. Example: 123456789,987654321
ADMIN_TELEGRAM_USER_IDS=

# Logging (optional)
# info | warn | error
LOG_LEVEL=info
